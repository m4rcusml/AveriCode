# Runtime connection. In Vercel + Supabase, use the shared transaction-mode pooler with pgbouncer=true.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/avericode?schema=public"

# Migration connection. In Vercel + Supabase, use the shared session-mode pooler or direct database URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/avericode?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# GitHub OAuth login. If omitted, the app falls back to the GitHub App client id/secret.
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""

GITHUB_APP_ID=""
GITHUB_APP_SLUG=""
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_PRIVATE_KEY_PATH=""
GITHUB_APP_WEBHOOK_SECRET=""

# Optional protection for /api/cron/weekly-sync.
CRON_SECRET=""
